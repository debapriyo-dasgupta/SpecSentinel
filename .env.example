# SpecSentinel Environment Configuration

# ── Logging Configuration ─────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable JSON logging (recommended for production)
JSON_LOGGING=false

# Enable file logging
FILE_LOGGING=true

# ── AI/LLM Configuration ──────────────────────────────────────────────────────
# OpenAI API Key (for GPT models)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Anthropic API Key (for Claude models)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# IBM WatsonX.ai Configuration (for Granite, Llama, Mixtral models)
# WATSONX_API_KEY=provide a key here
# WATSONX_PROJECT_ID=provide a project id here
# WATSONX_URL=https://us-south.ml.cloud.ibm.com
# WATSONX_MODEL=ibm/granite-13b-chat-v2

# Google API Key (for Gemini models)
# GOOGLE_API_KEY=...
# GOOGLE_MODEL=gemini-1.5-flash

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Enable multi-agent analysis (requires LLM)
USE_MULTI_AGENT=false

# ── AI Fix Generation Configuration ───────────────────────────────────────────
# Maximum number of findings to enhance with AI-generated fixes PER SEVERITY LEVEL
# Example: If set to 2 with 3 severities, you'll get 2×3 = 6 total AI fixes
AI_FIX_MAX_COUNT=2

# Severity levels to include for AI fix generation (comma-separated)
# Options: Critical, High, Medium, Low
AI_FIX_SEVERITIES=Critical,High,Medium

# ── Backend Configuration ─────────────────────────────────────────────────────
# Backend API URL (for frontend)
BACKEND_API_URL=http://localhost:8000

# ── Vector Database Configuration ─────────────────────────────────────────────
# ChromaDB persistence path (default: .chromadb)
# CHROMA_DB_PATH=.chromadb

# ── Ingestion Scheduler ───────────────────────────────────────────────────────
# Run ingestion on startup
RUN_INGESTION_ON_STARTUP=false

# Ingestion schedule: daily, weekly, monthly
INGESTION_SCHEDULE=weekly