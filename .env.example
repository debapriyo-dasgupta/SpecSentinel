# SpecSentinel Environment Configuration

# ── Logging Configuration ─────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable JSON logging (recommended for production)
JSON_LOGGING=false

# Enable file logging
FILE_LOGGING=true

# ── AI/LLM Configuration ──────────────────────────────────────────────────────
# OpenAI API Key (for GPT models)
# OPENAI_API_KEY=sk-...

# Anthropic API Key (for Claude models)
# ANTHROPIC_API_KEY=sk-ant-...

# Google API Key (for Gemini models)
# GOOGLE_API_KEY=...

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Enable multi-agent analysis (requires LLM)
USE_MULTI_AGENT=false

# ── Backend Configuration ─────────────────────────────────────────────────────
# Backend API URL (for frontend)
BACKEND_API_URL=http://localhost:8000

# ── Vector Database Configuration ─────────────────────────────────────────────
# ChromaDB persistence path (default: .chromadb)
# CHROMA_DB_PATH=.chromadb

# ── Ingestion Scheduler ───────────────────────────────────────────────────────
# Run ingestion on startup
RUN_INGESTION_ON_STARTUP=false

# Ingestion schedule: daily, weekly, monthly
INGESTION_SCHEDULE=weekly